{
  "name": "xms-calculator",
  "productName": "XMS Calculator",
  "version": "1.6.6",
  "description": "Royalty Calculator for XMusic Station based on ND 17/2023",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test test/*.test.js",
    "test:watch": "node --test --watch test/*.test.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac"
  },
  "author": "Archie",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "com.xmusic.calculator",
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ],
      "icon": "build/icons/app.icns"
    }
  },
  "repository": {
    "type": "git",
    "url": "TBD"
  },
  "bugs": {
    "url": "TBD"
  },
  "homepage": "TBD",
  "engines": {
    "node": ">=20"
  }
}
