{
  "name": "xmusic-station-calculator",
  "productName": "XMS Calculator",
  "version": "1.5.0",
  "description": "Royalty Calculator for XMusic Station based on ND 17/2023",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.xmusic.calculator",
    "files": [
      "main.js",
      "preload.js",
      "calculator.js",
      "app.js",
      "index.html",
      "styles.css",
      "vendor/**/*",
      "quote-template/**/*"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ],
      "icon": "512x512@2x.icns"
    }
  }
}
