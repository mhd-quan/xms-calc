{
  "name": "xms-calculator",
  "productName": "XMS Calculator",
  "version": "1.6.6",
  "description": "Royalty Calculator for XMusic Station based on ND 17/2023",
  "main": "out/main/index.js",
  "scripts": {
    "start": "npm run dev",
    "test": "node --test test/calculator.test.js",
    "test:watch": "node --test --watch test/calculator.test.js",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "electron-builder --mac",
    "policy:commit": "node scripts/policy/check-commit-convention.js",
    "policy:boundaries": "node scripts/policy/check-boundaries.js",
    "policy:strict": "node scripts/policy/check-strict-no-any.js",
    "phase:gate": "node scripts/policy/phase-gate.js",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b --pretty false",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext .js,.cjs,.mjs",
    "format": "prettier --write ."
  },
  "author": "Archie",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "typescript": "~5.6",
    "tsx": "~4.19",
    "electron-vite": "~2.3",
    "vite": "~5.4",
    "eslint": "~9.13",
    "typescript-eslint": "~8.11",
    "eslint-config-prettier": "~9.1",
    "eslint-plugin-import": "~2.31",
    "prettier": "~3.3",
    "@types/node": "~22.9",
    "@eslint/js": "~9.13"
  },
  "dependencies": {
    "pdf-lib": "^1.17.1"
  },
  "build": {
    "appId": "com.xmusic.calculator",
    "files": [
      "src/**/*",
      "!src/**/*.map"
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": [
        "dmg"
      ],
      "icon": "build/icons/app.icns"
    }
  },
  "repository": {
    "type": "git",
    "url": "TBD"
  },
  "bugs": {
    "url": "TBD"
  },
  "homepage": "TBD",
  "engines": {
    "node": ">=20"
  }
}
