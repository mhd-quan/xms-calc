{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true
  },
  "include": [
    "electron.vite.config.ts",
    "src/services/**/*.ts",
    "src/shared/**/*.ts",
    "src/types/**/*.d.ts",
    "test/**/*.ts"
  ]
}
